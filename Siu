    { name: "Περιβάλλον & Ανάπτυξη", grade: 6.1, sem: 4 },
    { name: "Στοιχεία Μηχανών ΙΙ", grade: 1.0, sem: 4 },
    { name: "Ηλεκτρικές Μηχανές", grade: 3.5, sem: 4 },
