    { name: "Αντοχή Υλικών", grade: 2.9, sem: 2 },
    { name: "Ηλεκτροτεχνία", grade: 5.0, sem: 2 },
    { name: "Μαθηματικά ΙΙ", grade: 3.0, sem: 2 },
    { name: "Μηχανική ΙI", grade: 8.5, sem: 2 },
    { name: "Μηχανολογική Σχεδίαση II", grade: 6.5, sem: 2 },
    { name: "Μηχανουργική Τεχνολογία Ι", grade: 6.6, sem: 2 },
    { name: "Εφαρμοσμένη Στατιστική", grade: 2.0, sem: 3 },
    { name: "Θερμοδυναμική Ι", grade: 5.0, sem: 3 },
    { name: "Μαθηματικά ΙΙI", grade: 1.0, sem: 3 },
    { name: "Στοιχεία Μηχανών Ι", grade: 1.0, sem: 3 },
