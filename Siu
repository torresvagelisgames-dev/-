    { name: "Υβριδικά Συστήματα", grade: 7.8, sem: 8 }
];
;

        function render() {
            const filter = document.getElementById('sortOrder').value;
            const container = document.getElementById('results');
            container.innerHTML = '';

            grades.forEach(item => {
                if (filter !== 'all' && item.sem != filter) return;

                const color = item.grade >= 5 ? 'text-green-400' : 'text-red-500';
                container.innerHTML += `
                    <div class="bg-gray-900 p-3 rounded-lg flex justify-between border border-gray-800">
                        <span>${item.name}</span>
                        <span class="font-bold ${color}">${item.grade.toFixed(1)}</span>
                    </div>`;
            });
        }
        render();
    </script>
</body>
</html>
